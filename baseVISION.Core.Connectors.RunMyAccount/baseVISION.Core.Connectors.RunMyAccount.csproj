<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <FileVersion>3.0.12.0</FileVersion>
    <Version>3.0.12</Version>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <AssemblyVersion>3.0.12</AssemblyVersion>
    <Copyright>baseVISION AG</Copyright>
    <PackageProjectUrl>https://github.com/ThomasKur/baseVISION.Tool.Connectors.RunMyAccount/</PackageProjectUrl>
    <Title>RunMyAccounts .NET API Library</Title>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
    <RepositoryType>git</RepositoryType>
    <PackageReleaseNotes>## Release Notes

